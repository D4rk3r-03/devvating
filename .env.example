# Claves de API — copia este archivo a .env y rellena tus valores.
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# Opcionales (valores por defecto entre paréntesis)
# DEVVATING_CLAUDE_MODEL=claude-opus-4-8
# DEVVATING_GEMINI_MODEL=gemini-3.5-flash
# DEVVATING_REPO_ROOT=.
# DEVVATING_MAX_TOOL_ITERATIONS=8
# DEVVATING_CLI_TIMEOUT=600   (segundos por turno de los backends cli; antigravity default 1500)
